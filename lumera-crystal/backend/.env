APP_NAME=LUMERA CRYSTAL API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_BASE_URL=http://localhost:8000
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
DATABASE_URL=postgresql+psycopg://postgres:123456@10.103.71.232:6543/lumera
ADMIN_JWT_SECRET=change-this-in-production
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXP_MINUTES=1440
ADMIN_DEFAULT_EMAIL=admin@lumeracrystal.com
ADMIN_DEFAULT_PASSWORD=Lumera@123456
MEDIA_MAX_UPLOAD_SIZE_MB=5
MEDIA_MAX_VIDEO_UPLOAD_SIZE_MB=20
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm,video/quicktime
MEDIA_MAX_DURATION_SECONDS=8
STOCK_LOW_THRESHOLD=5
AUTO_RESTOCK_QUANTITY=30
POINTS_EARN_RATE=10
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@lumeracrystal.com
SMTP_FROM_NAME=LUMERA CRYSTAL
MAIL_CONTACTS_PATH=config/mail_contacts.json
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_MODEL=qwen2.5:14b
LLM_TIMEOUT_SECONDS=20
CHAT_HISTORY_LIMIT=50
CHAT_HISTORY_FALLBACK=none
CAPABILITY_NEWS_ENABLED=true
CAPABILITY_NEWS_PROVIDER=juhe
CAPABILITY_NEWS_MAX_AGE_DAYS=30


# 资讯供应商配置（供应商层 - 以聚合数据 juhe 为例）
# -------------------------
# 聚合数据供应商基础地址（最小必填）
PROVIDER_JUHE_BASE_URL=http://apis.juhe.cn/fapigx

# 聚合数据供应商 API Key（最小必填）
PROVIDER_JUHE_API_KEY=55d59007407dcd98aed2fdb20862b8d4

# 聚合数据的资讯查询路径（最小必填）
PROVIDER_JUHE_NEWS_PATH=/internet_news/query

# 聚合数据接口超时时间（秒，可选，不填则默认 10）
PROVIDER_JUHE_TIMEOUT_SECONDS=8

# API key header（可选，不填则默认 Authorization）
PROVIDER_JUHE_KEY_HEADER=

# API key 前缀（可选，不填则默认 Bearer；若供应商不需要前缀可置空）
PROVIDER_JUHE_KEY_PREFIX=

# API key 在 query 中的参数名（聚合数据默认 key）
PROVIDER_JUHE_KEY_QUERY_PARAM=key

# 资讯关键词在 query 中的参数名（聚合数据默认 word）
PROVIDER_JUHE_QUERY_PARAM=word
