# -------------------------
# 基础配置
# -------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/lumera

# 独立物流服务（订单支付后自动创建物流轨迹）
LOGISTICS_SERVICE_ENABLED=true
LOGISTICS_SERVICE_BASE_URL=http://localhost:8010/api/v1/logistics
LOGISTICS_SERVICE_TIMEOUT_SECONDS=8

# 联系人映射 JSON 文件路径（默认 config/mail_contacts.json）
MAIL_CONTACTS_PATH=config/mail_contacts.json

# 本地模型提供方：openai 或 ollama
LLM_PROVIDER=ollama
# 本地模型服务地址
LLM_BASE_URL=http://localhost:11434
# OpenAI-compatible 可选 API Key
LLM_API_KEY=
# 模型名称
LLM_MODEL=
# LLM 请求超时时间（秒）
LLM_TIMEOUT_SECONDS=30

# 历史消息窗口大小
CHAT_HISTORY_LIMIT=50
# 历史存储 fallback（none 或 memory）
CHAT_HISTORY_FALLBACK=none

# -------------------------
# 资讯能力配置（能力层）
# -------------------------
# 是否启用资讯能力（最小必填）
CAPABILITY_NEWS_ENABLED=true

# 资讯能力当前使用的供应商标识，例如 juhe / tencent / aliyun（最小必填）
CAPABILITY_NEWS_PROVIDER=juhe

# 资讯能力默认返回条数（可选，不填则默认 5）
CAPABILITY_NEWS_DEFAULT_LIMIT=5

# 资讯能力“最新”判定的最大天数（可选，不填则默认 30 天）
CAPABILITY_NEWS_MAX_AGE_DAYS=30

# -------------------------
# 资讯供应商配置（供应商层 - 以聚合数据 juhe 为例）
# -------------------------
# 聚合数据供应商基础地址（最小必填）
PROVIDER_JUHE_BASE_URL=http://apis.juhe.cn/fapigx

# 聚合数据供应商 API Key（最小必填）
PROVIDER_JUHE_API_KEY=55d59007407dcd98aed2fdb20862b8d4

# 聚合数据的资讯查询路径（最小必填）
PROVIDER_JUHE_NEWS_PATH=/internet_news/query

# 聚合数据接口超时时间（秒，可选，不填则默认 10）
PROVIDER_JUHE_TIMEOUT_SECONDS=8

# API key header（可选；聚合数据默认走 query 参数，可留空）
PROVIDER_JUHE_KEY_HEADER=

# API key 前缀（可选；聚合数据默认走 query 参数，可留空）
PROVIDER_JUHE_KEY_PREFIX=

# API key 在 query 中的参数名（聚合数据默认 key）
PROVIDER_JUHE_KEY_QUERY_PARAM=key

# 资讯关键词在 query 中的参数名（聚合数据默认 word）
PROVIDER_JUHE_QUERY_PARAM=word

# -------------------------
# 已废弃（Deprecated）旧版资讯配置
# -------------------------
# 兼容旧配置，仅用于短期迁移
NEWS_API_ENABLED=false
NEWS_API_BASE_URL=
NEWS_API_PATH=
NEWS_API_KEY=
NEWS_API_TIMEOUT_SECONDS=10
NEWS_API_KEY_HEADER=Authorization
NEWS_API_KEY_PREFIX=Bearer
NEWS_API_DEFAULT_LIMIT=5
